{
	"geode": "5.3.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "oki3ed.rbg",
	"name": "Background Customization",
	"version": "v2.0.0",
	"developer": "CMDs",
	"description": "Customize background in different menus",
	"early-load": true,
	"links": {
		"source": "https://github.com/oki333ed/Rand-BG-Color"
	},
    "dependencies": {
        "geode.node-ids": ">=v1.23.0",
        "alphalaneous.happy_textures": ">=v2.1.0",
		"prevter.imageplus": ">=v1.1.0"
    },
	"settings": {
		"layers": {
			"type": "title",
			"name": "Layers",
			"description": "Indicates on which layers the custom background will be"
		},
        "loadinglayer": {
            "default": true,
            "name": "Loading Screen (LoadingLayer)",
            "type": "bool"
        },
        "gjgaragelayer": {
            "default": false,
            "name": "Icon Kit Menu (GJGarageLayer)",
            "type": "bool"
        },
        "creatorlayer": {
            "default": true,
            "name": "Creator Menu (CreatorLayer)",
            "type": "bool"
        },
        "gauntletlayer": {
            "default": false,
            "name": "Gauntlet Menu (GauntletLayer)",
            "type": "bool"
        },
        "cvoltonbetterinfobackground": {
            "default": false,
            "name": "cvolton.betterinfo/background",
            "description": "Better Info layers example cvolton.betterinfo/CustomCreatorLayer",
            "type": "bool"
        },
        "globedlayers": {
            "default": false,
            "name": "Globed Layers",
            "type": "bool"
        },
        "secretlayers": {
            "default": false,
            "name": "Secret Layers",
            "type": "bool"
        },
        "levelinfolayer": {
            "default": true,
            "name": "Level Info (LevelInfoLayer)",
            "type": "bool"
        },
		"additions": {
			"type": "title",
			"name": "Additions",
			"description": "Additions Features"
		},
		"bg-texture": {
			"default": "{gd_resources_dir}/GJ_gradientBG-hd.png",
		    "name": "Background Texture",
			"description": "Custom background texture :3",
			"type": "file",
		    "control": {
		        "dialog": "open",
		        "filters": [
		            {
		                "files": ["*.png", "*.webp", "*.gif"],
		                "description": "Images files"
		            }
		        ]
		    }
		},
        "custombackgroundcolors": {
            "default": false,
            "name": "Custom Background Colors",
            "description": "Custom background colors :D"
        },
        "colors": {
            "default": "{\"colors\":[{\"r\":0,\"g\":102,\"b\":255},{\"r\":255,\"g\":76,\"b\":0},{\"r\":255,\"g\":171,\"b\":0},{\"r\":255,\"g\":236,\"b\":0},{\"r\":167,\"g\":255,\"b\":0},{\"r\":0,\"g\":234,\"b\":255},{\"r\":0,\"g\":39,\"b\":255},{\"r\":126,\"g\":0,\"b\":255},{\"r\":232,\"g\":0,\"b\":255},{\"r\":223,\"g\":223,\"b\":223},{\"r\":148,\"g\":148,\"b\":148},{\"r\":69,\"g\":69,\"b\":69},{\"r\":76,\"g\":76,\"b\":76},{\"r\":164,\"g\":0,\"b\":255},{\"r\":40,\"g\":40,\"b\":40},{\"r\":37,\"g\":50,\"b\":167},{\"r\":75,\"g\":10,\"b\":0},{\"r\":0,\"g\":60,\"b\":180}]}",
            "name": "Colors",
            "description": "BG Colors (Json format: {\"colors\":[{\"r\":100,\"g\":100,\"b\":100}]},{\"r\":0,\"g\":34,\"b\":155}]})",
            "enable-if": "custombackgroundcolors",
            "type": "string"
        },
        "randomcolors": {
            "default": true,
            "name": "Random Colors",
            "description": "Made random colors (not from list).\nYes setting \"Colors\" will not change colors if this Random Colors true",
            "enable-if": "custombackgroundcolors",
            "type": "bool"
        }
	}
}